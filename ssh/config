Host *
    UserKnownHostsFile ~/.config/ssh/known_hosts

Host *
    IdentityAgent ~/.1password/agent.sock

Host github github.com
    HostName github.com
    User git
    IdentityFile ~/.config/ssh/github
    IdentityAgent none

